      "parameters": {
        "jsCode": "const raw = $json.text;\nconst limpio = JSON.parse(raw);\n\n// Limpiar CIF: quitar guiones, espacios y convertir a mayúsculas\nlimpio.cif_limpio = limpio.cif ? limpio.cif.replace(/[-\\s]/g, '').toUpperCase() : '';\n\n// Si no hay datos suficientes para crear factura, la saltamos\nif (!limpio.proveedor && !limpio.total) {\n  return [];\n}\n\nreturn [{ json: limpio }];"
      },
